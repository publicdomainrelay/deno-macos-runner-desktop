{
  "name": "macos-runner-desktop",
  "description": "macOS compute provider desktop app with DeviceCheck attestation + ATProto OAuth + market bidder",
  "options": {
    "service-name": {
      "type": "string",
      "description": "Service name for logging",
      "env": "SERVICE_NAME",
      "default": "macos-runner-desktop"
    },
    "bridge-path": {
      "type": "string",
      "description": "Path to devicecheck_bridge.dylib",
      "env": "BRIDGE_PATH",
      "default": "./devicecheck_bridge.dylib"
    },
    "state-path": {
      "type": "string",
      "description": "Path to provider state JSON",
      "env": "STATE_PATH"
    },
    "oauth-client-id": {
      "type": "string",
      "description": "OAuth client_id URL",
      "env": "OAUTH_CLIENT_ID",
      "default": "https://attest--johnandersen777-bsky-social.fedproxy.com/oauth-client-metadata.json"
    },
    "oauth-redirect-uri": {
      "type": "string",
      "description": "OAuth redirect URI (custom URL scheme)",
      "env": "OAUTH_REDIRECT_URI",
      "default": "com.fedproxy.attest--johnandersen777-bsky-social:/callback"
    },
    "dispatcher-host": {
      "type": "string",
      "description": "XRPC relay dispatcher host for market bidder",
      "env": "RELAY_DISPATCHER_HOST",
      "default": "xrpc.fedproxy.com"
    },
    "plc-directory-url": {
      "type": "string",
      "description": "PLC directory URL for DID resolution",
      "env": "PLC_DIRECTORY_URL",
      "default": "https://plc.directory"
    },
    "firehose-url": {
      "type": "string",
      "description": "Firehose WebSocket URL for RFP discovery (jetstream or subscribeRepos)",
      "env": "FIREHOSE_URL"
    },
    "offering-refresh-sec": {
      "type": "number",
      "description": "Seconds between offering record re-commits (0 to disable)",
      "env": "OFFERING_REFRESH_SEC",
      "default": 300
    },
    "skip-market": {
      "type": "boolean",
      "description": "Skip market bidder initialization (escape hatch for npm dep issues)",
      "env": "SKIP_MARKET"
    }
  }
}
