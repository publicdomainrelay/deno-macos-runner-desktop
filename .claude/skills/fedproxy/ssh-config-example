# SSH config snippet for FedProxy persistent tunnels
#
# Add this to ~/.ssh/config (create the file if it doesn't exist).
# Then connect with: ssh fedproxy-myapp
#
# For multiple services, duplicate the Host block with different names
# and -R arguments.

Host fedproxy-myapp
    HostName fedproxy.com
    Port 2222
    User your-handle
    IdentityFile ~/.ssh/fedproxy
    UserKnownHostsFile /dev/null
    StrictHostKeyChecking no
    PasswordAuthentication no
    ServerAliveInterval 60
    ExitOnForwardFailure yes
    RemoteForward myapp:80:127.0.0.1:8080
    SessionType none
    RequestTTY no

# Example for a second service on a different port
# Host fedproxy-api
#     HostName fedproxy.com
#     Port 2222
#     User your-handle
#     IdentityFile ~/.ssh/fedproxy
#     UserKnownHostsFile /dev/null
#     StrictHostKeyChecking no
#     PasswordAuthentication no
#     ServerAliveInterval 60
#     ExitOnForwardFailure yes
#     RemoteForward api:80:127.0.0.1:3000
#     SessionType none
#     RequestTTY no


# ── macOS launchd plist ──────────────────────────────────────────────
# Save as ~/Library/LaunchAgents/com.fedproxy.myapp.plist
# Load with: launchctl load ~/Library/LaunchAgents/com.fedproxy.myapp.plist
# Unload with: launchctl unload ~/Library/LaunchAgents/com.fedproxy.myapp.plist

